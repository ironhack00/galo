---
import Base from '../layouts/Base.astro';
import TriBg from '../components/TriBg.astro';
import FounderSection from '../components/FounderSection.astro';
import ContactSection from '../components/ContactSection.astro';
import { pillars, brandMeaning } from '../data/site.js';
---
<Base title="Nosotros" description="Los pilares de GALO Marketing: creatividad, planificación y estrategia. Conocé el significado de la marca y a su fundador.">
  <section class="pillars tri-bg section" aria-labelledby="pil-h">
    <TriBg />
    <div class="container">
      <h1 class="h-section center pillars__head" id="pil-h" data-reveal>Nuestros pilares</h1>
      <div class="pillars__grid">
        {pillars.map((p) => (
          <div class="pillar" data-reveal>
            <div class="pillar__top">
              <span class="pillar__n">{p.n}</span>
              <h2 class="pillar__title h-sub">{p.title}</h2>
            </div>
            <p class="pillar__text text-justify">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section brand" aria-labelledby="brand-h">
    <div class="container">
      <header class="brand__head" data-reveal>
        <p class="eyebrow">La marca</p>
        <h2 class="h-section" id="brand-h">GALO</h2>
        <p class="lead max-60">Surge de la unión de dos conceptos inspiradores.</p>
      </header>
      <div class="brand__grid">
        {brandMeaning.map((b) => (
          <div class="brand__item" data-reveal>
            <span class="brand__ico"><img src={b.icon} alt="" width="70" height="70" /></span>
            <h3 class="h-sub">{b.title}</h3>
            <p class="text-muted">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FounderSection heading="El fundador" />

  <ContactSection />
</Base>

<style>
  .pillars { overflow: hidden; }
  .pillars__head { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .pillars__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.5rem, 4vw, 3rem); }
  .pillar__top { display: flex; align-items: center; gap: .8rem; margin-bottom: 1rem; }
  .pillar__n {
    font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 6vw, 4.2rem);
    line-height: 1; color: var(--gold); -webkit-text-stroke: 0;
  }
  .pillar__title { color: #fff; }
  .pillar__text { color: rgba(255,255,255,.82); font-size: .96rem; }

  .brand { background: var(--bg-soft); }
  .brand__head { text-align: center; display: grid; justify-items: center; gap: .6rem; margin-bottom: clamp(2rem, 5vw, 3rem); }
  .brand__head .lead { margin-inline: auto; }
  .brand__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(1.2rem, 3vw, 2rem); max-width: 900px; margin-inline: auto; }
  .brand__item {
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 3vw, 2.4rem); text-align: center; display: grid; justify-items: center; gap: .9rem;
    transition: transform .2s ease, border-color .2s ease;
  }
  .brand__item:hover { transform: translateY(-6px); border-color: var(--green); }
  .brand__ico {
    width: 100px; height: 100px; display: grid; place-items: center; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(35,161,43,.25), transparent 75%);
  }
  .brand__ico img { width: 62px; height: 62px; object-fit: contain; }

  @media (max-width: 820px) {
    .pillars__grid { grid-template-columns: 1fr; gap: 2rem; }
    .brand__grid { grid-template-columns: 1fr; }
  }
</style>
