---
const { service } = Astro.props;
const href = `/servicios/${service.slug}/`;
---
<a class="svc" href={href} data-reveal>
  <div class="svc__inner">
    <div class="svc__media">
      <img src={service.img} alt="" width="240" height="180" loading="lazy" decoding="async" />
    </div>
    <div class="svc__body">
      <h3 class="svc__title">{service.title}</h3>
      <p class="svc__desc">{service.short}</p>
    </div>
    <span class="svc__more plus-info">+ info</span>
  </div>
</a>

<style>
  .svc {
    display: block;
    filter: drop-shadow(0 24px 40px rgba(0, 0, 0, .35));
    transition: transform .25s ease, filter .25s ease;
  }
  .svc:hover { transform: translateY(-8px); filter: drop-shadow(0 30px 48px rgba(35, 161, 43, .28)); }

  .svc__inner {
    background: #fff; color: var(--ink);
    /* Forma de banderín: base con punta hacia abajo al centro */
    clip-path: polygon(0 0, 100% 0, 100% 90%, 50% 100%, 0 90%);
    padding: 20px 22px 56px;
    height: 100%;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    border-top: 4px solid var(--green);
  }

  .svc__media {
    width: 100%; background: #ededed; border-radius: 12px;
    padding: 14px; display: grid; place-items: center; margin-bottom: 1.1rem;
  }
  .svc__media img { width: auto; max-height: 130px; object-fit: contain; }

  .svc__body { flex: 1; }
  .svc__title {
    font-family: var(--font-display); font-weight: 600; font-size: 1.15rem;
    color: var(--green-deep); line-height: 1.15; margin-bottom: .55rem;
    transition: color .2s ease;
  }
  .svc:hover .svc__title { color: var(--green); }
  .svc__desc { color: #55605a; font-size: .92rem; line-height: 1.5; }

  .svc__more { margin-top: 1rem; letter-spacing: .01em; }
  .svc:hover .svc__more { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 520px) {
    .svc__inner { padding: 16px 14px 48px; }
    .svc__title { font-size: 1rem; }
    .svc__desc { font-size: .82rem; }
  }
</style>
