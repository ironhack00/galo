---
import TriBg from './TriBg.astro';
import { site } from '../data/site.js';
const { heading = 'Acerca de GALO' } = Astro.props;
const f = site.founder;
---
<section class="founder tri-bg section always-dark" id="fundador" aria-labelledby="founder-h">
  <TriBg />
  <div class="container">
    <h2 class="h-section center" id="founder-h" data-reveal>{heading}</h2>

    <div class="founder__grid">
      <figure class="founder__photo" data-reveal>
        <img src="/assets/img/fundador.png" alt={`${f.name}, ${f.role} de ${site.name}`} width="804" height="1400" loading="lazy" decoding="async" />
      </figure>

      <div class="founder__text" data-reveal>
        <p class="eyebrow">{f.role}</p>
        <h3 class="h-sub">{f.name}</h3>
        <p class="founder__intro">{f.intro}</p>
        {f.bio.map((para) => <p class="founder__para text-justify">{para}</p>)}
      </div>
    </div>
  </div>
</section>

<style>
  .founder { overflow: hidden; }
  .founder .h-section { margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .founder__grid {
    display: grid; grid-template-columns: minmax(240px, 420px) 1fr;
    gap: clamp(1.5rem, 5vw, 4rem); align-items: center;
  }
  .founder__photo { margin: 0; align-self: end; }
  .founder__photo img {
    width: 100%; height: auto; max-height: 560px; object-fit: contain;
    filter: drop-shadow(0 30px 40px rgba(0,0,0,.5));
  }
  .founder__text .eyebrow { margin-bottom: .3rem; }
  .founder__text .h-sub { margin-bottom: 1rem; }
  .founder__intro { font-size: 1.1rem; font-weight: 500; margin-bottom: 1.2rem; color: #fff; }
  .founder__para { color: rgba(255,255,255,.82); margin-bottom: .9rem; font-size: .96rem; }

  @media (max-width: 820px) {
    .founder__grid { grid-template-columns: 1fr; }
    .founder__photo { max-width: 340px; margin-inline: auto; }
    .founder__text { text-align: center; }
    .founder__text .founder__para { text-align: left; }
  }
</style>
