---
import Logo from './Logo.astro';
import { nav, site } from '../data/site.js';
const year = 2025;
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <Logo />
      <p class="footer__tag">Creatividad, planificación y estrategia para llevar tu marca a su máximo potencial.</p>
      <div class="footer__social">
        <a class="social" href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
          <span class="social__ico" style="--m:url(/assets/icons/ig.svg)"></span>
        </a>
        <a class="social" href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook">
          <span class="social__ico" style="--m:url(/assets/icons/fb.svg)"></span>
        </a>
      </div>
    </div>

    <nav class="footer__col" aria-label="Menú del pie">
      <h4 class="footer__title">Menú</h4>
      <ul>
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h4 class="footer__title">Contacto</h4>
      <ul class="footer__contact">
        <li>{site.address}</li>
        <li><a href={`tel:${site.phoneRaw}`}>{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bar">
    Copyright © {year} {site.name}. Un desarrollo de GGF.
  </div>
</footer>

<style>
  .footer { background: var(--bg-soft); border-top: 1px solid var(--line); }
  .footer__inner {
    display: grid; grid-template-columns: 1.6fr 1fr 1.2fr; gap: 2.5rem;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .footer__tag { color: var(--muted); max-width: 34ch; margin-top: 1rem; font-size: .95rem; }
  .footer__social { display: flex; gap: .8rem; margin-top: 1.4rem; }
  .footer .social__ico { width: 28px; height: 28px; background: var(--green); -webkit-mask: var(--m) center/contain no-repeat; mask: var(--m) center/contain no-repeat; transition: background .2s ease, transform .2s ease; }
  .footer .social:hover .social__ico { background: var(--green-bright); transform: translateY(-2px); }

  .footer__title { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; margin-bottom: 1rem; color: #fff; }
  .footer__col ul { display: grid; gap: .6rem; }
  .footer__col a, .footer__contact li { color: var(--muted); transition: color .2s ease; }
  .footer__col a:hover { color: var(--green-bright); }
  .footer__contact { font-size: .95rem; }

  .footer__bar {
    background: var(--green); color: #fff; text-align: center;
    font-size: .85rem; font-weight: 500; padding: .9rem 1rem;
  }

  @media (max-width: 760px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
