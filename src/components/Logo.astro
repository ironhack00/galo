---
// Logo GALO Marketing: triángulo invertido + gaviota (SVG oficiales de marca).
// Escala con la altura del contenedor y se puede recolorear vía currentColor.
const { size = 44, href = '/' } = Astro.props;
---
<a class="logo" href={href} aria-label="GALO Marketing — Inicio">
  <svg class="logo__mark" width={size} height={size} viewBox="0 0 64 64" fill="none" aria-hidden="true">
    <!-- Triángulo invertido -->
    <path d="M4 6 H60 L32 58 Z" stroke="currentColor" stroke-width="3.2"
          stroke-linejoin="round" fill="none"/>
    <!-- Gaviota (trazado oficial, viewBox original 274.06 × 176.96) -->
    <g transform="translate(19 15) scale(0.095)" fill="currentColor">
      <path d="M152.31,106.69c-7.67,4.79-15.35,9.58-23.09,14.41-.68-3.73-1.36-7.89-2.2-12.02-5.18-25.4-17.15-47.29-34.67-66.22-1.19-1.29-3.56-1.89-5.46-2.06-23.84-2.13-46.91-7-67.79-19.31C12.74,17.74,6.88,13.12,0,8.35c1.77-.73,2.37-1.12,3.03-1.24C29.96,2.33,56.99-1.38,84.46.5c22.92,1.57,44.65,7.3,64.87,18.46,3.02,1.67,4.53,3.66,4.76,7.16.56,8.61,1.13,17.23,2.25,25.77,2.1,16.12,11.89,26.65,25.81,33.84,1.09.56,2.79.53,4.01.15,7.12-2.22,14.31-2.54,21.75-2.21,5.81.25,11.73-.89,17.54-1.81,4.43-.7,5.74-.56,7.44,2.43-2.17,1.34-4.46,2.51-6.48,4.05-4.82,3.67-8.9,7.81-11.85,13.41-8.74,16.6-22.61,27.87-39.58,35.33-6.57,2.89-13.59,4.76-20.31,7.34-2.31.89-4.63,2.19-6.44,3.85-5.3,4.88-10.05,10.38-15.56,14.99-8.93,7.49-16.51,7.18-25.15-.64-3.4-3.08-6.3-6.72-9.42-10.11.5-.69.65-1.14.93-1.25,13.22-5.34,23.41-14.75,33.34-24.58,6.65-6.58,13.65-12.82,20.49-19.21-.18-.26-.35-.53-.53-.79Z"/>
      <path d="M270.12,176.96c-5.68-7.75-11.06-15.74-17.12-23.17-5.75-7.05-11.74-14.04-18.45-20.14-9.29-8.43-20.2-12.2-32.75-7.32-.3.12-.72-.04-1.47-.09,2.57-2.89,5.23-5.36,7.25-8.28,3.35-4.84,6.26-9.98,9.42-14.95.65-1.02,1.46-2.35,2.46-2.66,9.53-2.94,19.22-4.94,29.24-2.97,12.96,2.56,19.61,11.44,22.77,23.48,3.79,14.46,2.72,29.1,1.2,43.72-.42,4.06-1.08,8.1-1.63,12.15-.3.07-.61.15-.91.22Z"/>
    </g>
  </svg>
  <span class="logo__word">
    <strong>GALO</strong>
    <em>marketing</em>
  </span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: .55rem; color: var(--text); }
  .logo__mark { flex: none; }
  .logo__word { display: grid; line-height: 1; }
  .logo__word strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: .04em;
  }
  .logo__word em {
    font-style: normal;
    font-weight: 400;
    font-size: .62rem;
    letter-spacing: .42em;
    text-transform: lowercase;
    color: var(--muted);
    margin-top: 2px;
    padding-left: 2px;
  }
</style>
