---
import { site } from '../data/site.js';
const msg = encodeURIComponent('¡Hola GALO Marketing! Quiero hacer una consulta.');
const url = `https://wa.me/${site.phoneRaw}?text=${msg}`;
---
<a class="wa-fab" href={url} target="_blank" rel="noopener" aria-label="Escribinos por WhatsApp">
  <svg viewBox="0 0 32 32" width="30" height="30" fill="#fff" aria-hidden="true">
    <path d="M16.02 3.2c-7.04 0-12.76 5.72-12.76 12.76 0 2.25.59 4.44 1.71 6.38L3.2 28.8l6.64-1.74a12.7 12.7 0 0 0 6.17 1.57h.01c7.04 0 12.76-5.72 12.76-12.76 0-3.41-1.33-6.61-3.74-9.02a12.68 12.68 0 0 0-9.02-3.65Zm0 23.3h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-4.06 1.06 1.08-3.95-.25-.4a10.55 10.55 0 0 1-1.62-5.63c0-5.85 4.76-10.6 10.62-10.6 2.83 0 5.5 1.1 7.5 3.11a10.55 10.55 0 0 1 3.1 7.5c0 5.85-4.76 10.6-10.61 10.6Zm5.82-7.94c-.32-.16-1.89-.93-2.18-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.58a9.6 9.6 0 0 1-1.78-2.21c-.19-.32-.02-.49.14-.65.15-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.73-.99-2.37-.26-.62-.52-.54-.72-.55l-.61-.01c-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.66 0 1.57 1.14 3.08 1.3 3.29.16.21 2.24 3.42 5.43 4.8.76.33 1.35.52 1.81.67.76.24 1.45.21 2 .13.61-.09 1.89-.77 2.15-1.52.27-.75.27-1.38.19-1.52-.08-.13-.29-.21-.61-.37Z"/>
  </svg>
</a>

<style>
  .wa-fab {
    position: fixed; right: clamp(16px, 3vw, 28px); bottom: clamp(16px, 3vw, 28px);
    z-index: 60; width: 58px; height: 58px; border-radius: 50%;
    display: grid; place-items: center;
    background: #25d366;
    box-shadow: 0 12px 30px -8px rgba(37, 211, 102, .6), 0 4px 10px rgba(0,0,0,.3);
    transition: transform .2s ease, box-shadow .2s ease;
    animation: wa-pulse 2.6s infinite;
  }
  .wa-fab:hover { transform: scale(1.08); }
  @keyframes wa-pulse {
    0%   { box-shadow: 0 12px 30px -8px rgba(37,211,102,.6), 0 0 0 0 rgba(37,211,102,.45); }
    70%  { box-shadow: 0 12px 30px -8px rgba(37,211,102,.6), 0 0 0 16px rgba(37,211,102,0); }
    100% { box-shadow: 0 12px 30px -8px rgba(37,211,102,.6), 0 0 0 0 rgba(37,211,102,0); }
  }
  @media (prefers-reduced-motion: reduce) { .wa-fab { animation: none; } }
</style>
